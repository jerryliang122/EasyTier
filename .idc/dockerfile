# EasyTier 开发环境 Dockerfile
# 基于 Ubuntu 24.04，支持 Rust、Node.js、Android 开发

FROM ubuntu:24.04

# 设置非交互式安装
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Shanghai

# 设置工作目录
WORKDIR /workspace

# 更新系统并安装基础依赖
RUN apt-get update && apt-get install -y \
    # 基础工具
    curl wget git vim nano \
    build-essential pkg-config cmake \
    # Rust 和 C++ 编译环境
    clang lld \
    # 网络工具
    net-tools iproute2 bridge-utils \
    # 图形界面依赖（Tauri 需要）
    libayatana-appindicator3-dev \
    libwebkit2gtk-4.1-dev \
    libssl-dev \
    libsoup-3.0-dev \
    libgtk-3-dev \
    libglib2.0-dev \
    libcairo2-dev \
    libpango1.0-dev \
    libgdk-pixbuf2.0-dev \
    # OpenSSL 和其他安全库
    openssl \
    libclang-dev \
    llvm \
    # 压缩工具
    zstd \
    # 内存分配器
    jemalloc \
    # Java 环境（Android 开发需要）
    openjdk-21-jdk \
    # Node.js 和 pnpm
    nodejs npm \
    # 其他工具
    protobuf-compiler \
    protobuf-compiler-grpc \
    # 清理
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 安装 Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    && source "$HOME/.cargo/env" \
    && rustup default stable \
    && rustup update stable \
    && rustup component add rust-src rust-analyzer clippy

# 安装 Node.js 和 pnpm（使用 NodeSource 获取最新版本）
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g pnpm

# 下载并安装 Android SDK 和 NDK
ENV ANDROID_SDK_ROOT=/opt/android/sdk
ENV ANDROID_NDK_ROOT=/opt/android/ndk
ENV NDK_HOME=/opt/android/ndk/26.1.10909125
ENV JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64

# 创建 Android 目录
RUN mkdir -p /opt/android

# 下载 Android 命令行工具
RUN wget -q https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip -O /tmp/cmdline-tools.zip \
    && unzip /tmp/cmdline-tools.zip -d /tmp/ \
    && mkdir -p ${ANDROID_SDK_ROOT}/cmdline-tools \
    && mv /tmp/cmdline-tools ${ANDROID_SDK_ROOT}/cmdline-tools/latest \
    && rm /tmp/cmdline-tools.zip

# 设置 Android SDK 和 NDK
RUN yes | ${ANDROID_SDK_ROOT}/cmdline-tools/latest/bin/sdkmanager --sdk_root=${ANDROID_SDK_ROOT} "build-tools;34.0.0" \
    && yes | ${ANDROID_SDK_ROOT}/cmdline-tools/latest/bin/sdkmanager --sdk_root=${ANDROID_SDK_ROOT} "platforms;android-34" \
    && yes | ${ANDROID_SDK_ROOT}/cmdline-tools/latest/bin/sdkmanager --sdk_root=${ANDROID_SDK_ROOT} "ndk;26.1.10909125"

# 设置环境变量
ENV PATH=${ANDROID_SDK_ROOT}/cmdline-tools/latest/bin:${ANDROID_SDK_ROOT}/platform-tools:${PATH}
ENV LIBCLANG_PATH=/usr/lib/x86_64-linux-gnu
ENV BINDGEN_EXTRA_CLANG_ARGS="-I/usr/lib/x86_64-linux-gnu/include"
ENV LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH
ENV ZSTD_SYS_USE_PKG_CONFIG=true
ENV KCP_SYS_EXTRA_HEADER_PATH=/usr/lib/x86_64-linux-gnu/include
ENV JEMALLOC_OVERRIDE=/usr/lib/x86_64-linux-gnu/libjemalloc.so
ENV RUST_SRC_PATH=/root/.rustup/toolchains/stable-x86_64-unknown-linux-gnu/lib/rustlib/src/rust/library

# 设置 Rust Android targets
RUN source "$HOME/.cargo/env" \
    && rustup target add aarch64-linux-android \
    && rustup target add armv7-linux-androideabi \
    && rustup target add i686-linux-android \
    && rustup target add x86_64-linux-android \
    && rustup target add aarch64-unknown-linux-musl \
    && rustup target add x86_64-unknown-linux-musl

# 创建项目目录
RUN mkdir -p /workspace/src/easytier

# 设置端口映射
EXPOSE 11010/tcp 11010/udp 11011/udp 11011/tcp 11012/tcp

# 设置 Shell 配置
RUN echo 'source $HOME/.cargo/env' >> /root/.bashrc \
    && echo 'export PS1="\[\e[36m\]EasyTier-Dev\[\e[0m\] \[\e[33m\]\w\[\e[0m\]\\$ "' >> /root/.bashrc

# 创建启动脚本
RUN cat > /root/entrypoint.sh << 'EOF'
#!/bin/bash
echo "🚀 EasyTier 开发环境已准备就绪！"
echo ""
echo "📋 可用命令："
echo "  - cargo build --release     # 编译 Rust 项目"
echo "  - pnpm install              # 安装前端依赖"
echo "  - pnpm dev                  # 启动前端开发服务器"
echo "  - pnpm tauri dev            # 启动 Tauri GUI 开发"
echo "  - easytier-core --help      # 查看 EasyTier 核心帮助"
echo ""
echo "🔧 环境配置："
echo "  - Rust: $(rustc --version)"
echo "  - Node.js: $(node --version)"
echo "  - pnpm: $(pnpm --version)"
echo "  - Java: $(java --version 2>&1 | head -n 1)"
echo ""
echo "📱 Android 开发："
echo "  - SDK_ROOT: $ANDROID_SDK_ROOT"
echo "  - NDK_ROOT: $NDK_HOME"
echo ""
echo "💡 提示：使用 'cd /workspace/src' 进入项目目录"
echo ""

exec "$@"
EOF

RUN chmod +x /root/entrypoint.sh

# 设置入口点
ENTRYPOINT ["/root/entrypoint.sh", "bash"]

# 默认命令
CMD ["/bin/bash"]